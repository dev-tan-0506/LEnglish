    "@nestjs/platform-express": "^11.0.7",
    "@prisma/client": "^6.19.3",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.2",
    "@nestjs/testing": "^11.0.7",
    "@swc/core": "^1.15.33",
    "@types/cookie-parser": "^1.4.10",
    "@types/supertest": "^7.2.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.2.1",
